#!/usr/bin/env bash
# SessionStart hook for hi-claude: injects the Constitution into every session.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

constitution=$(cat "${PLUGIN_ROOT}/skills/memory-protocol/constitution.md" 2>&1 || echo "hi-claude: constitution.md not found")

# Escape for JSON embedding (single C-level pass per substitution).
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

payload=$(escape_for_json "$constitution")
printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "<hi-claude-method>\\n%s\\n</hi-claude-method>"\n  }\n}\n' "$payload"
exit 0
